ANTHROPIC_API_KEY=your-key-here
ABUSEIPDB_API_KEY=
NOTIFY_WEBHOOK=
JWT_SECRET=change-me-please
DST_LAT=40.4168
DST_LNG=-3.7038
DST_LABEL=HQ
APPLY_FIREWALL=false
AUTH_REQUIRED=false
ADMIN_EMAIL=admin@autosoc.local
ADMIN_PASSWORD=admin

# Access token TTL minutes / refresh TTL hours
ACCESS_TTL_MIN=15
REFRESH_TTL_HOURS=336

# MFA issuer name shown in authenticator apps
MFA_ISSUER=AutoSoc

# OIDC SSO (Auth0/Okta/Google/Azure compatible). Leave empty to disable.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback
OIDC_DEFAULT_ROLE=viewer
