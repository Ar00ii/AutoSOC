# Required for docker-compose
JWT_SECRET=                # python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_EMAIL=admin@autosoc.local
ADMIN_PASSWORD=            # python -c "import secrets; print(secrets.token_urlsafe(24))"

# Optional
ANTHROPIC_API_KEY=
ABUSEIPDB_API_KEY=
NOTIFY_WEBHOOK=
APPLY_FIREWALL=false
ACCESS_TTL_MIN=15
REFRESH_TTL_HOURS=336
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://your-domain/api/auth/oidc/callback
OIDC_DEFAULT_ROLE=viewer
